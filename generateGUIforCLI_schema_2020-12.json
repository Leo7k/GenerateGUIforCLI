{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "description": {
      "type": "string"
    },
    "defaultArgumentNameValueSeparator": {
      "type": "string"
    },
    "defaultSelectMultipleValueSeparator": {
      "type": "string"
    },
    "defaultSelectMultipleQuotationSymbol": {
      "type": "string"
    },
    "defaultQuotationSymbol": {
      "type": "string",
      "default": "\""
    },
    "defaultBooleanTrue": {
      "type": "string",
      "default": "true"
    },
    "defaultBooleanFalse": {
      "type": "string",
      "default": "false"
    },
    "sections": {
      "type": "array",
      "uniqueItems": true,
      "items": {
          "type": "object",
          "properties": {
            "displayName": {
              "type": "string"
            },
            "args": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                  "type": "object",
                  "properties": {
                    "booleanTrue": {
                      "type": "string"
                    },
                    "booleanFalse": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    },
                    "type": {
                      "type": "string",
                      "enum": ["boolean", "input-file", "input-file-multiple", "number", "output-file", "string", "select-one", "select-multiple"]
                    },
                    "required": {
                      "type": "boolean"
                    },
                    "displayName": {
                      "type": "string"
                    },
                    "dontIncludeName": {
                      "type": "boolean"
                    },
                    "quotationSymbol": {
                      "type": "string"
                    },
                    "defaultValue": {
                       "oneOf": [{
                          "type": "string"
                        },
                        {
                           "type": "boolean"
                        },
                        {
                           "type": "number"
                        }
                      ]
                     },
                    "nameValueSeparator": {
                      "type": "string"
                    },
                    "options": {
                       "type": "array",
                       "uniqueItems": true,
                       "items": {
                          "type": "object",
                          "properties": {
                             "value": {
                               "type": "string"
                             },
                             "displayValue": {
                               "type": "string"
                             }
                          },
                          "required": [
                            "value"
                          ]
                       }
                    }
                  },
                  "required": [
                    "name",
                    "type",
                    "displayName"
                  ]
                }
            }
          },
          "required": [
            "displayName",
            "args"
          ]
        }
    }
  },
  "required": [
    "defaultArgumentNameValueSeparator",
    "defaultSelectMultipleValueSeparator",
    "defaultSelectMultipleQuotationSymbol",
    "defaultQuotationSymbol",
    "defaultBooleanTrue",
    "defaultBooleanFalse",
    "sections"
  ]
}